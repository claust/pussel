// Copy this file to Secrets.xcconfig (gitignored) and fill in real values.
// Re-running `xcodegen generate` is not needed afterwards — just rebuild.
//
// GOOGLE_IOS_CLIENT_ID:
//   Google Cloud Console -> APIs & Services -> Credentials -> Create OAuth
//   client ID -> type "iOS", bundle id dk.delectosoft.pussel. Use the SAME
//   GCP project as the existing web client.
// GOOGLE_URL_SCHEME:
//   The iOS client id with its segments reversed:
//   com.googleusercontent.apps.<numeric-prefix-part-of-the-ios-client-id>
// GOOGLE_SERVER_CLIENT_ID:
//   The EXISTING web GOOGLE_CLIENT_ID from backend/.env — the backend
//   verifies Google ID tokens against this audience. Do not create a new one.

// DEVELOPMENT_TEAM:
//   Your 10-character Apple Developer Team ID — required for device builds,
//   not for Simulator builds. Find it via Xcode > Settings > Accounts or in
//   your signing certificate's OU field.

GOOGLE_IOS_CLIENT_ID = YOUR_IOS_CLIENT_ID.apps.googleusercontent.com
GOOGLE_SERVER_CLIENT_ID = YOUR_WEB_CLIENT_ID.apps.googleusercontent.com
GOOGLE_URL_SCHEME = com.googleusercontent.apps.YOUR_IOS_CLIENT_ID
DEVELOPMENT_TEAM = YOUR_TEAM_ID
