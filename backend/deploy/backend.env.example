# Production env for the pussel backend on delectosoft.
# Copy to /home/claus/pussel/backend.env (outside the git checkout) and fill in.

ENVIRONMENT=production

# openssl rand -base64 32
JWT_SECRET=fill-me-in

# Same Google OAuth client the iOS app authenticates against.
GOOGLE_CLIENT_ID=fill-me-in.apps.googleusercontent.com

# JSON array; empty/unset would let ANY Google account sign in.
ALLOWED_EMAILS=["you@example.com"]

# The backend sits behind Traefik (which overwrites/appends
# X-Forwarded-For), so the rightmost entry is proxy-authored and safe to
# use for per-IP rate limiting. See app/config.py::TRUST_PROXY_HEADERS.
TRUST_PROXY_HEADERS=true
